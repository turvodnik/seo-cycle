# =============================================================================
# .env.example — шаблон env vars для seo-cycle проекта
# =============================================================================
# 1. Скопируй: cp ~/.codex/skills/seo-cycle/.env.example .env
# 2. Заполни значениями (см. docs/oauth-setup.md для каждого)
# 3. Добавь .env в .gitignore проекта

# -----------------------------------------------------------------------------
# Runtime routing
# -----------------------------------------------------------------------------
# bootstrap-codex.sh пишет: SEO_RUNTIME=codex + SEO_SEARCH_RUNTIME=direct
# bootstrap-claude.sh пишет: SEO_RUNTIME=claude + SEO_SEARCH_RUNTIME=codex_external
# Для ручной настройки оставь auto или выбери явно.
SEO_RUNTIME=auto
SEO_SEARCH_RUNTIME=auto

# -----------------------------------------------------------------------------
# Google APIs (GSC, GA4, PSI) — через service account
# -----------------------------------------------------------------------------
# Путь к JSON ключу service account
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/google-credentials.json

# Search Console — формат: sc-domain:example.com  или  https://example.com/
GSC_SITE_URL=

# GA4 Property ID (числовой, не measurement ID типа G-XXX)
GA4_PROPERTY_ID=

# PageSpeed Insights — опционально (без ключа лимит 25 req/день)
# PSI_API_KEY=

# Google Merchant / Business / YouTube (опц.; без установки analytics tag)
# GOOGLE_MERCHANT_ACCOUNT_ID=
# GOOGLE_BUSINESS_ACCOUNT_ID=
# GOOGLE_BUSINESS_LOCATION_ID=
# YOUTUBE_CHANNEL_ID=

# -----------------------------------------------------------------------------
# Яндекс (Метрика + Вебмастер) — через OAuth токен
# -----------------------------------------------------------------------------
YANDEX_OAUTH_TOKEN=
YANDEX_METRIKA_COUNTER_ID=
YANDEX_USER_ID=
YANDEX_WEBMASTER_HOST_ID=
# YANDEX_MERCHANT_BUSINESS_ID=
# YANDEX_DIRECT_CLIENT_LOGIN=

# -----------------------------------------------------------------------------
# Bing / Microsoft webmaster & indexing (опц., без analytics tag)
# -----------------------------------------------------------------------------
# BING_WEBMASTER_API_KEY=
# BING_SITE_URL=https://example.com/
# INDEXNOW_KEY=
# INDEXNOW_KEY_LOCATION=https://example.com/<indexnow-key>.txt
# MICROSOFT_TENANT_ID=
# MICROSOFT_CLIENT_ID=
# MICROSOFT_CLIENT_SECRET=

# -----------------------------------------------------------------------------
# NeuronWriter (опц., только если включён в sources.neuronwriter)
# -----------------------------------------------------------------------------
# NEURON_API_KEY=
# NEURON_PLAN=
# NEURON_PROJECT_ID=
# NEURON_LIMITS_FILE=seo/neuronwriter-limits.yaml
# NEURON_DEFAULT_ENGINE=google.ru
# NEURON_DEFAULT_LANGUAGE=Russian
# NEURON_DEFAULT_COMPETITORS_MODE=top-intent

# -----------------------------------------------------------------------------
# Google Cloud Natural Language / NLP entity audit (опц., billing-gated)
# -----------------------------------------------------------------------------
# GOOGLE_NLP_ENABLED=0
# GOOGLE_NLP_API=language.googleapis.com
# GOOGLE_NLP_BILLING_APPROVED=0
# GOOGLE_NLP_CLOUD_BUDGET_USD=5
# GOOGLE_NLP_BUDGET_STATUS=disabled_until_budget_and_local_guards
# GOOGLE_NLP_MODE=free_first_applicable_only
# GOOGLE_NLP_DEFAULT_FEATURES=analyzeEntities,classifyText,analyzeSyntax
# GOOGLE_NLP_ALLOWED_FEATURES=analyzeEntities,classifyText,analyzeSyntax,moderateText,analyzeSentiment,analyzeEntitySentiment
# GOOGLE_NLP_DISABLED_FEATURES_FOR_RU=analyzeSentiment,analyzeEntitySentiment
# GOOGLE_NLP_USE_ONLY_IMPORTANT_URLS=1
# GOOGLE_NLP_FREE_ENTITY_UNITS_PER_MONTH=5000
# GOOGLE_NLP_FREE_SYNTAX_UNITS_PER_MONTH=5000
# GOOGLE_NLP_FREE_SENTIMENT_UNITS_PER_MONTH=5000
# GOOGLE_NLP_FREE_ENTITY_SENTIMENT_UNITS_PER_MONTH=5000
# GOOGLE_NLP_FREE_CLASSIFICATION_UNITS_PER_MONTH=30000
# GOOGLE_NLP_FREE_MODERATION_UNITS_PER_MONTH=50000
# GOOGLE_NLP_PAID_ENTITY_UNITS_CAP_PER_MONTH=5000
# GOOGLE_NLP_PAID_SYNTAX_UNITS_CAP_PER_MONTH=0
# GOOGLE_NLP_PAID_CLASSIFICATION_UNITS_CAP_PER_MONTH=0
# GOOGLE_NLP_PAID_MODERATION_UNITS_CAP_PER_MONTH=0
# GOOGLE_NLP_PAID_SENTIMENT_UNITS_CAP_PER_MONTH=0
# GOOGLE_NLP_PAID_ENTITY_SENTIMENT_UNITS_CAP_PER_MONTH=0
# GOOGLE_NLP_TOTAL_ENTITY_UNITS_CAP_PER_MONTH=10000
# GOOGLE_NLP_TOTAL_SYNTAX_UNITS_CAP_PER_MONTH=5000
# GOOGLE_NLP_TOTAL_CLASSIFICATION_UNITS_CAP_PER_MONTH=30000
# GOOGLE_NLP_TOTAL_MODERATION_UNITS_CAP_PER_MONTH=50000
# GOOGLE_NLP_TOTAL_SENTIMENT_UNITS_CAP_PER_MONTH=5000
# GOOGLE_NLP_TOTAL_ENTITY_SENTIMENT_UNITS_CAP_PER_MONTH=5000
# GOOGLE_NLP_MAX_URLS_PER_RUN=50
# GOOGLE_NLP_MAX_CHARS_PER_URL=10000
# GOOGLE_NLP_CACHE_DAYS=30
# GOOGLE_NLP_CACHE_DIR=seo/cache/google-nlp
# GOOGLE_NLP_POLICY_FILE=seo/entities/google-nlp-policy.yaml

# -----------------------------------------------------------------------------
# AnswerThePublic (опц., только en/us — RU не поддерживается)
# -----------------------------------------------------------------------------
# TOKEN_ANSWERTHEPUBLIC=atp_pk_live_...

# -----------------------------------------------------------------------------
# WordPress publishing (только если publishing.cms = wordpress)
# -----------------------------------------------------------------------------
# WP_BASE_URL=https://example.com
# WP_USER=admin
# WP_APP_PASSWORD=xxxx xxxx xxxx xxxx
# WOO_REST_API_KEY=ck_...
# WOO_REST_API_SECRET=cs_...

# WordPress MCP / Novomira (project-local, optional)
# These are not WordPress REST credentials. They are read only by the local
# .codex/config.toml MCP wrapper for @automattic/mcp-wordpress-remote.
# WP_API_URL=https://example.com/wp-json/mcp/novamira
# WP_API_USERNAME=
# WP_API_PASSWORD=

# WordPress SSH/WP-CLI media upload (scripts/wp-photo-image.py)
# SSH_HOST=example.com
# SSH_PORT=22
# SSH_USER=ssh-user
# SSH_PASSWORD=
# WP_REMOTE_ROOT=/home/user/example.com/public_html

# -----------------------------------------------------------------------------
# DataForSEO (опц., платная подписка)
# -----------------------------------------------------------------------------
# DATAFORSEO_LOGIN=
# DATAFORSEO_PASSWORD=

# -----------------------------------------------------------------------------
# Serpstat (опц.) — volume/KD/CPC + конкуренты, работает с РФ/СНГ (g_ru).
# Беречь кредиты (план Appsumo: 1000/мес, 1 req/sec). scripts/serpstat-fetch.py
# -----------------------------------------------------------------------------
# SERPSTAT_API_KEY=

# -----------------------------------------------------------------------------
# XMLRiver (опц.) — guarded Google/Yandex SERP + Wordstat New enrichment.
# Live-запросы только после spend-guard и с --live --allow-paid.
# -----------------------------------------------------------------------------
# XMLRIVER_USER_ID=
# XMLRIVER_API_KEY=

# -----------------------------------------------------------------------------
# Keys.so (опц.) — Яндекс/РФ-данные: Wordstat-частоты, видимость, конкуренты,
# потерянные ключи. Лимит 10 запросов/10сек. scripts/keyso-fetch.py
# -----------------------------------------------------------------------------
# KEYSO_API_TOKEN=

# -----------------------------------------------------------------------------
# SpyFu (опц.) — competitor/PPC/SEO для US/UK/EU. ⚠ НЕ покрывает РФ/Яндекс.
# Pro = $40 кредита/мес (pay-as-you-go по строкам). scripts/spyfu-fetch.py
# -----------------------------------------------------------------------------
# API_SpyFu_ID=
# API_SpyFu_secret_key=

# -----------------------------------------------------------------------------
# Telegram уведомления (опц., notifications.enabled). scripts/notify.py
# BOT_TOKEN от @BotFather, CHAT_ID от @userinfobot. Без них — graceful no-op.
# -----------------------------------------------------------------------------
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=

# -----------------------------------------------------------------------------
# LLM CLI overrides (опц.)
# -----------------------------------------------------------------------------
# NW_DEFAULT_ENGINE=google.ru
# NW_DEFAULT_LANGUAGE=Russian
# LLMCLI_LANG=ru
# LLMCLI_REGION="Москва и Московская область"
